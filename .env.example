# =============================================================================
# .env.example — Variables de configuration Pipeline ETL Marchés Publics
# Copier en .env et renseigner toutes les valeurs avant lancement
# =============================================================================

# ─── Google Sheets ────────────────────────────────────────────────────────────
# ID dans l'URL : https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=

# Nom de la feuille dans le Google Sheet
SHEET_NAME=Marchés

# ─── Google Drive ─────────────────────────────────────────────────────────────
# ID du dossier racine Drive où seront créés les sous-dossiers par offre
DRIVE_FOLDER_ID=

# Chemin vers le fichier token Google OAuth2
TOKEN_PATH=token.json

# ─── Email SMTP ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=portailmpma@gmail.com
# App Password Gmail (Compte Google > Sécurité > Mots de passe des applications)
SMTP_PASSWORD=

# Email destinataire des alertes offres prioritaires
ALERT_EMAIL=portailmpma@gmail.com

# Email destinataire du rapport quotidien
REPORT_EMAIL=portailmpma@gmail.com

# ─── Formulaire DCE ───────────────────────────────────────────────────────────
# Informations utilisées pour remplir le formulaire de téléchargement DCE
DCE_NOM=Portail
DCE_PRENOM=MPMA
DCE_EMAIL=portailmpma@gmail.com

# ─── Seuils d'alerte ──────────────────────────────────────────────────────────
# Budget minimum pour déclencher une alerte (en DH)
BUDGET_SEUIL=70000000

# Nombre de jours restants minimum pour déclencher une alerte
JOURS_SEUIL=30

# Nombre de jours avant expiration pour inclure dans le rapport
JOURS_ALERTE=7

# ─── Ollama / IA locale ───────────────────────────────────────────────────────
# Modèle à utiliser :
#   mistral        4.1 Go  — ✅ recommandé (VM partagée Moodle+ERPNext)
#   llama3.1       4.7 Go  — bon en français
#   gemma2         5.4 Go  — bon en français
#   mixtral:8x7b   26 Go   — ⚠️ trop lourd sur VM partagée
#   phi3           2.3 Go  — léger si RAM critique
#
# NOTE : VM partagée avec Moodle (~4Go) + ERPNext (~6Go) = ~10Go occupés en permanence
# RAM disponible pour le pipeline : ~12-14 Go → mistral est le bon choix
OLLAMA_MODEL=mistral

# Activer l'extraction IA (true/false)
OLLAMA_ENABLED=true

# ─── Pipeline ─────────────────────────────────────────────────────────────────
# Nombre max de tentatives avant abandon d'une offre en erreur
MAX_RETRY=3

# Nombre d'offres traitées par session (batch)
# VM partagée → batch modéré pour ne pas saturer la RAM
BATCH_SIZE=50

# Nombre de workers parallèles pour l'analyse PDF
# VM partagée → 2 workers max pour ne pas impacter Moodle/ERPNext
ANALYZER_WORKERS=2

# ─── Contraintes VM partagée ──────────────────────────────────────────────────
# Limite CPU pour le pipeline (nice) — évite d'impacter Moodle/ERPNext
# Le main.sh applique automatiquement nice +10 et ionice
CPU_NICE=10
